package-as: Brannfred
enable-nolib-creation: no

ignore:
  - scripts
  - media

move-folders:
  Brannfred/Providers/Calculator: Brannfred_Calc
  Brannfred/Providers/EquipSets: Brannfred_EquipSets
  Brannfred/Providers/Friends: Brannfred_Friends
  Brannfred/Providers/History: Brannfred_History
  Brannfred/Providers/Inventory: Brannfred_Inventory
  Brannfred/Providers/ItemDB: Brannfred_ItemDB
  Brannfred/Providers/Menus: Brannfred_Menus
  Brannfred/Providers/Quests: Brannfred_Quests
  Brannfred/Providers/Spells: Brannfred_Spells

optional-dependencies:
  - 914482-baganator
  - 18808-tomtom
  - 334372-questie
  - 988370-syndicator
  - 1441253-itemrack-anniversary
  - 3831-ludwig
